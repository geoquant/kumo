---
import themeMetadata from "@cloudflare/kumo/ai/theme-metadata.json";
import DocLayout from "../layouts/DocLayout.astro";
import ComponentSection from "../components/docs/ComponentSection.astro";
import CodeBlock from "../components/docs/CodeBlock.astro";
import Callout from "../components/docs/Callout.astro";
import { TailwindColorTokens } from "../components/demos/ColorsDemo";

const availableThemes = [...themeMetadata.themes];
const nonDefaultThemes = availableThemes.filter((theme) => theme !== "kumo");
const exampleTheme = nonDefaultThemes[0] ?? "fedramp";
const themeSummaries = availableThemes.map((theme) => ({
  name: theme,
  overrideCount:
    theme === "kumo"
      ? 0
      : themeMetadata.tokens.filter((token) => token.themes[theme] !== undefined)
          .length,
}));
const inheritedCardStyle =
  "color-scheme: light dark; background-color: light-dark(var(--color-kumo-neutral-25, oklch(98.5% 0 0)), var(--color-neutral-950, oklch(14.5% 0 0))); border-color: light-dark(oklch(14.5% 0 0 / 0.1), var(--color-neutral-800, oklch(26.9% 0 0)));";
const inheritedPanelStyle =
  "color-scheme: light dark; background-color: light-dark(var(--color-kumo-neutral-25, oklch(99% 0 0)), var(--color-kumo-neutral-975, oklch(8.5% 0 0))); border-color: light-dark(oklch(14.5% 0 0 / 0.1), var(--color-neutral-800, oklch(26.9% 0 0)));";
const inheritedSampleStyle =
  "color-scheme: light dark; background-color: light-dark(var(--color-white, #fff), var(--color-kumo-neutral-850, oklch(22.4% 0 0))); border-color: light-dark(oklch(14.5% 0 0 / 0.1), var(--color-neutral-800, oklch(26.9% 0 0))); color: light-dark(var(--color-neutral-900, oklch(21% 0.006 285.885)), var(--color-neutral-100, oklch(97% 0 0)));";
const inheritedTextStyle =
  "color-scheme: light dark; color: light-dark(var(--color-neutral-900, oklch(21% 0.006 285.885)), var(--color-neutral-100, oklch(97% 0 0)));";
const inheritedSubtleTextStyle =
  "color-scheme: light dark; color: light-dark(var(--color-neutral-600, oklch(43.9% 0 0)), var(--color-neutral-400, oklch(70.8% 0 0)));";
---

<DocLayout
  title="Colors"
  description="Kumo uses semantic color tokens that automatically adapt to light and dark mode. Use these classes in your Tailwind CSS instead of raw color values."
>
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Usage</h2>
    <p class="mb-4 text-kumo-strong">
      Always use semantic tokens instead of raw Tailwind colors. This ensures your UI
      automatically adapts to light and dark mode.
    </p>
    <div class="space-y-4">
      <div>
        <p class="mb-2 text-sm font-medium text-kumo-default">Correct</p>
        <CodeBlock
          code={`<div className="bg-kumo-base text-kumo-default border-kumo-line">
  <button className="bg-kumo-brand text-white">Primary</button>
  <button className="bg-kumo-control text-kumo-default">Secondary</button>
</div>`}
          lang="tsx"
        />
      </div>
      <div>
        <p class="mb-2 text-sm font-medium text-kumo-default">Incorrect</p>
        <CodeBlock
          code={`<!-- Never use raw Tailwind colors -->
<div className="bg-white ${"dark:bg-gray-900"} text-black ${"dark:text-white"}">
  <button className="${"bg-blue-500"}">Primary</button>
</div>`}
          lang="tsx"
        />
      </div>
    </div>
    <div class="mt-6">
      <Callout type="warning">
        <strong>Lint rules enforce this:</strong> The <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">no-primitive-colors</code> 
        rule will flag any raw Tailwind colors like <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">{`bg-${"blue-500"}`}</code>.
      </Callout>
    </div>
  </ComponentSection>

  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Mode</h2>
    <p class="mb-4 text-kumo-strong">
      Set <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">data-mode</code> on a parent element to force light or dark.
      If you do nothing, tokens inherit the current user/system preference via <a class="underline decoration-kumo-line underline-offset-2" href="https://web.dev/articles/light-dark">light-dark()</a>.
    </p>
    <div class="mb-6 grid gap-4 md:grid-cols-3">
      <div class="rounded-xl border border-kumo-line bg-kumo-elevated p-4" data-mode="light" style="color-scheme: light;">
        <p class="text-sm font-medium text-kumo-default">Light</p>
        <div class="mt-3 rounded-lg border border-kumo-line bg-kumo-surface p-3">
          <div class="rounded-md border border-kumo-line bg-kumo-base px-3 py-4 text-sm text-kumo-default"><code>bg-kumo-surface</code></div>
        </div>
      </div>
      <div class="rounded-xl border border-kumo-line bg-kumo-elevated p-4" data-mode="dark" style="color-scheme: dark;">
        <p class="text-sm font-medium text-kumo-default">Dark</p>
        <div class="mt-3 rounded-lg border border-kumo-line bg-kumo-surface p-3">
          <div class="rounded-md border border-kumo-line bg-kumo-base px-3 py-4 text-sm text-kumo-default"><code>bg-kumo-surface</code></div>
        </div>
      </div>
      <div class="rounded-xl border border-kumo-line p-4" style={inheritedCardStyle}>
        <p class="text-sm font-medium" style={inheritedTextStyle}>Inherited</p>
        <div class="mt-3 rounded-lg border p-3" style={inheritedPanelStyle}>
          <div class="rounded-md border px-3 py-4 text-sm" style={inheritedSampleStyle}><code>light-dark(...)</code></div>
        </div>
        <p class="mt-2 text-xs" style={inheritedSubtleTextStyle}>current user/system</p>
      </div>
    </div>
    <CodeBlock
      code={`// Set mode on html or body
<html data-mode="light">  // Light mode
<html data-mode="dark">   // Dark mode

// Components automatically adapt - no dark: variants needed
<div className="bg-kumo-base text-kumo-default" />`}
      lang="tsx"
    />
  </ComponentSection>

  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Themes</h2>
    <p class="mb-4 text-kumo-strong">
      Themes override semantic token values while preserving the same token names.
      Set <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">data-theme</code> on a parent element to apply a theme.
    </p>

    <div class="mb-6">
      <h3 class="mb-2 text-lg font-semibold">Available Themes</h3>
      <ul class="list-inside list-disc space-y-1 text-kumo-strong">
        {themeSummaries.map((theme) => (
          <li>
            <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">{theme.name}</code>
            {" — "}
            {theme.name === "kumo"
              ? "Default theme (no attribute needed)"
              : `${theme.overrideCount} token overrides`}
          </li>
        ))}
      </ul>
    </div>

    <CodeBlock
      code={`// Apply a theme to a section or the whole app
<div data-theme="${exampleTheme}">
  {/* All Kumo components inside use ${exampleTheme} token overrides */}
  <Button>${exampleTheme} Styled</Button>
</div>

// Themes work with both light and dark mode
<html data-mode="dark" data-theme="${exampleTheme}">`}
      lang="tsx"
    />

    <div class="mt-6">
      <h3 class="mb-2 text-lg font-semibold">Theme Generator</h3>
      <p class="mb-4 text-kumo-strong">
        Themes are defined in a centralized config and generated as CSS files plus machine-readable metadata. The generator keeps package exports and docs in sync.
      </p>
      <CodeBlock
        code={`# List all tokens and their theme overrides
pnpm --filter @cloudflare/kumo codegen:themes --list

# Generate theme CSS files
pnpm --filter @cloudflare/kumo codegen:themes

# Inspect generated theme metadata
cat packages/kumo/ai/theme-metadata.json

# Preview changes without writing files
pnpm --filter @cloudflare/kumo codegen:themes --dry-run`}
        lang="bash"
      />
      <p class="mt-4 text-kumo-strong">
        Theme config: <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">packages/kumo/scripts/theme-generator/config.ts</code>
      </p>
    </div>

    <div class="mt-6">
      <h3 class="mb-2 text-lg font-semibold">Creating a New Theme</h3>
      <p class="mb-4 text-kumo-strong">
        Add theme overrides in the config file. Only override tokens that need to change—all other tokens inherit from the base kumo theme.
      </p>
      <CodeBlock
        code={`// In scripts/theme-generator/config.ts
export const THEME_CONFIG: ThemeConfig = {
  color: {
    "kumo-base": {
      newName: "",
      theme: {
        kumo: {
          light: "var(--color-white, #fff)",
          dark: "var(--color-black, #000)",
        },
        // Add your theme override
        myTheme: {
          light: "#f0f4f8",
          dark: "#1a1f2e",
        },
      },
    },
    // ... other tokens
  },
};

// Add to available themes
export const AVAILABLE_THEMES = [${availableThemes.map((theme) => `"${theme}"`).join(", ")}, "myTheme"] as const;`}
        lang="ts"
      />
      <p class="mt-4 text-kumo-strong">
        Then run <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">pnpm codegen:themes</code> to generate the CSS and metadata. Make sure the generated theme stylesheet is imported before using the new <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">data-theme</code> value.
      </p>
    </div>
  </ComponentSection>

  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Adding Tokens</h2>
    <p class="mb-4 text-kumo-strong">
      If no existing semantic token fits, add a new token in the theme config instead of hardcoding a hex value in a component.
    </p>
    <CodeBlock
      code={`// 1. Add the token in packages/kumo/scripts/theme-generator/config.ts
"kumo-card": {
  newName: "",
  theme: {
    kumo: {
      light: "var(--color-kumo-neutral-25, oklch(98.5% 0 0))",
      dark: "var(--color-kumo-neutral-900, oklch(20% 0 0))",
    },
  },
}

// 2. Regenerate theme outputs
pnpm --filter @cloudflare/kumo codegen:themes

// 3. Use the semantic class in components
<div className="bg-kumo-card border-kumo-line text-kumo-default" />`}
      lang="tsx"
    />
    <ul class="mt-4 list-inside list-disc space-y-1 text-kumo-strong">
      <li>Source of truth: <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">config.ts</code></li>
      <li>Generated outputs: <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">src/styles/theme-*.css</code> and <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">ai/theme-metadata.json</code></li>
      <li>Available classnames follow the token name: <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">bg-kumo-card</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">text-kumo-card</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">border-kumo-card</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">ring-kumo-card</code></li>
    </ul>
  </ComponentSection>

  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Token Reference</h2>
    <p class="mb-4 text-kumo-strong">
      Use the mode toggle in the header to inspect light and dark values. The token values shown below are generated from Kumo theme metadata.
    </p>
    <TailwindColorTokens client:load />
  </ComponentSection>
</DocLayout>
