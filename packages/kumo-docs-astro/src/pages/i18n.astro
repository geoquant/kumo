---
import DocLayout from "../layouts/DocLayout.astro";
import ComponentSection from "../components/docs/ComponentSection.astro";
import CodeBlock from "../components/docs/CodeBlock.astro";
import Callout from "../components/docs/Callout.astro";
import { I18nSwitchGridDemo } from "../components/demos/I18nDemo";
---

<DocLayout
  title="Internationalization"
  description="Kumo provides a built-in localization system with 12 locale bundles, RTL support, and type-safe translation lookups."
>
  <!-- Overview -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Overview</h2>
    <p class="mb-4 text-kumo-strong">
      Kumo ships with a lightweight i18n system for built-in UI strings. The
      system is designed to be zero-config for most use cases:
    </p>
    <ul class="mb-4 list-inside list-disc space-y-1 text-kumo-strong">
      <li>12 built-in locale bundles registered automatically on import</li>
      <li>Locale detected from <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">&lt;html lang&gt;</code> attribute (reactive)</li>
      <li>RTL support via logical CSS properties</li>
      <li>Provider-scoped controls for aliasing, diagnostics, and direction</li>
      <li>Type-safe translation keys with parameterized string support</li>
      <li>Override any string via component <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">labels</code> props</li>
    </ul>
    <p class="mb-4 text-kumo-strong">
      English is the canonical source for all terms. Other locale bundles may
      fall back to English for keys that are not yet overridden.
    </p>
  </ComponentSection>

  <!-- Supported Locales -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Supported Locales</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-kumo-line text-start">
            <th class="px-3 py-2 text-start font-medium text-kumo-default">Code</th>
            <th class="px-3 py-2 text-start font-medium text-kumo-default">Name</th>
            <th class="px-3 py-2 text-start font-medium text-kumo-default">Direction</th>
          </tr>
        </thead>
        <tbody class="text-kumo-strong">
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">en</code></td><td class="px-3 py-2">English</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">ar</code></td><td class="px-3 py-2">العربية</td><td class="px-3 py-2">RTL</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">de</code></td><td class="px-3 py-2">Deutsch</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">es</code></td><td class="px-3 py-2">Español</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">fr</code></td><td class="px-3 py-2">Français</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">he</code></td><td class="px-3 py-2">עברית</td><td class="px-3 py-2">RTL</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">it</code></td><td class="px-3 py-2">Italiano</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">ja</code></td><td class="px-3 py-2">日本語</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">ko</code></td><td class="px-3 py-2">한국어</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">pt</code></td><td class="px-3 py-2">Português</td><td class="px-3 py-2">LTR</td></tr>
          <tr class="border-b border-kumo-line"><td class="px-3 py-2"><code class="text-sm">zh-CN</code></td><td class="px-3 py-2">简体中文</td><td class="px-3 py-2">LTR</td></tr>
          <tr><td class="px-3 py-2"><code class="text-sm">zh-TW</code></td><td class="px-3 py-2">繁體中文</td><td class="px-3 py-2">LTR</td></tr>
        </tbody>
      </table>
    </div>
  </ComponentSection>

  <!-- Direction and State Matrix -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Example</h2>
    <p class="mb-4 text-kumo-strong">
      This matrix shows the same four translated switch labels in each quadrant,
      combining layout direction (<code class="rounded bg-kumo-control px-1 py-0.5 text-sm">LTR</code> / <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">RTL</code>) with label placement (<code class="rounded bg-kumo-control px-1 py-0.5 text-sm">controlFirst=true</code> / <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">controlFirst=false</code>).
    </p>
    <I18nSwitchGridDemo client:visible />
  </ComponentSection>

  <!-- Quick Start -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Quick Start</h2>
    <p class="mb-4 text-kumo-strong">
      Kumo reads the <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">&lt;html lang&gt;</code> attribute to determine the active locale. Set it to a supported BCP 47 code:
    </p>
    <CodeBlock
      code={`<!-- Your HTML -->
<html lang="es">
  <!-- Kumo resolves locale as "es" for this document -->
</html>`}
      lang="tsx"
    />
    <p class="mt-4 mb-4 text-kumo-strong">
      If your app changes locale at runtime, mutate the attribute — Kumo components re-render automatically via a <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">MutationObserver</code>:
    </p>
    <CodeBlock
      code={`document.documentElement.lang = "fr"; // Components re-render with locale "fr"`}
      lang="ts"
    />
  </ComponentSection>

  <!-- Locale Resolution -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Locale Resolution</h2>
    <p class="mb-4 text-kumo-strong">
      The locale is resolved in this order:
    </p>
    <ol class="mb-4 list-inside list-decimal space-y-1 text-kumo-strong">
      <li>Nearest <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">KumoLocaleProvider</code> <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">locale</code> prop</li>
      <li>If <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">detectLocale</code> is <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">true</code> (default): <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">&lt;html lang&gt;</code> then <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">navigator.language</code></li>
      <li>If <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">detectLocale</code> is <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">false</code> and no explicit locale is set: <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">"en"</code></li>
    </ol>
    <CodeBlock
      code={`import { KumoLocaleProvider } from "@cloudflare/kumo";

// Force a subtree to use a specific locale
<KumoLocaleProvider locale="de">
  <MyComponent /> {/* Locale resolves as "de" */}
</KumoLocaleProvider>`}
      lang="tsx"
    />
    <div class="mt-4">
      <Callout type="info">
        Controlled mode uses an explicit <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">locale</code>. Uncontrolled mode omits <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">locale</code> and follows detection defaults.
      </Callout>
    </div>
  </ComponentSection>

  <!-- Provider Configuration -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Provider Configuration</h2>
    <p class="mb-4 text-kumo-strong">
      <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">KumoLocaleProvider</code> supports scoped i18n controls. Nested providers inherit parent settings unless overridden.
    </p>
    <CodeBlock
      code={`import { KumoLocaleProvider } from "@cloudflare/kumo";

<KumoLocaleProvider
  localeAliases={{ "en-US": "en", "es-PE": "es" }}
  detectLocale={false}
  direction="ltr"
  warnOnUnknownLocale
  onUnknownLocale={(diagnostic) => {
    // diagnostic.reason: "invalid" | "unsupported"
    // diagnostic.resolvedTranslationCode: fallback used for rendering
  }}
>
  <App />
</KumoLocaleProvider>`}
      lang="tsx"
    />
    <ul class="mt-4 mb-4 list-inside list-disc space-y-1 text-kumo-strong">
      <li><code class="rounded bg-kumo-control px-1 py-0.5 text-sm">localeAliases</code>: maps locale inputs to canonical locale codes before lookup</li>
      <li><code class="rounded bg-kumo-control px-1 py-0.5 text-sm">detectLocale</code>: toggles html/navigator detection when <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">locale</code> is omitted</li>
      <li><code class="rounded bg-kumo-control px-1 py-0.5 text-sm">direction</code>: explicit subtree direction override</li>
      <li><code class="rounded bg-kumo-control px-1 py-0.5 text-sm">onUnknownLocale</code>: callback for invalid/unsupported inputs with diagnostic payload</li>
      <li><code class="rounded bg-kumo-control px-1 py-0.5 text-sm">warnOnUnknownLocale</code>: dev warning once per normalized unknown locale</li>
    </ul>
  </ComponentSection>

  <!-- Translation Resolution -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Translation Resolution</h2>
    <p class="mb-4 text-kumo-strong">
      Once a locale is determined, Kumo resolves the translation object:
    </p>
    <ol class="mb-4 list-inside list-decimal space-y-1 text-kumo-strong">
      <li><strong>Exact match</strong> — <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">"zh-CN"</code> finds the <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">zh-CN</code> translation</li>
      <li><strong>Language prefix</strong> — <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">"es-PE"</code> falls back to <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">es</code></li>
      <li><strong>Fallback</strong> — English (the first registered translation)</li>
    </ol>
    <div class="mt-4 space-y-4">
      <Callout type="info">
        Fallback is non-breaking: unknown locales still render via fallback translation, and missing keys always resolve per-key from English.
      </Callout>
      <Callout type="warning">
        Unknown locale diagnostics classify failures as <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">invalid</code> (bad BCP 47 token) or <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">unsupported</code> (valid token, no matching translation).
      </Callout>
    </div>
  </ComponentSection>

  <!-- RTL Support -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">RTL Support</h2>
    <p class="mb-4 text-kumo-strong">
      Kumo uses CSS logical properties throughout, so layouts automatically mirror in RTL mode.
      Set <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">dir="rtl"</code> on a parent element:
    </p>
    <CodeBlock
      code={`<html lang="ar" dir="rtl">
  <!-- All Kumo components render right-to-left -->
</html>`}
      lang="tsx"
    />
    <p class="mt-4 mb-4 text-kumo-strong">
      You can also scope RTL to a subtree using <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">DirectionProvider</code>:
    </p>
    <p class="mb-4 text-kumo-strong">
      Kumo's <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">DirectionProvider</code> is a Kumo context utility with Base UI-compatible direction semantics.
      See <a class="underline" href="https://base-ui.com/react/utils/direction-provider" target="_blank" rel="noreferrer">Base UI direction docs</a> for the underlying direction model.
    </p>
    <CodeBlock
      code={`import { DirectionProvider } from "@cloudflare/kumo";

<DirectionProvider direction="rtl">
  <MyArabicSection />
</DirectionProvider>`}
      lang="tsx"
    />
    <div class="mt-4 space-y-4">
      <Callout type="info">
        Direction precedence inside <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">KumoLocaleProvider</code> is: explicit <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">direction</code> prop, then locale-derived direction, then <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">ltr</code>.
      </Callout>
      <Callout type="info">
        Components use logical CSS properties like <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">ps-*</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">pe-*</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">start-*</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">end-*</code> instead of <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">pl-*</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">pr-*</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">left-*</code>, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">right-*</code>. This is enforced by lint rules.
      </Callout>
    </div>
  </ComponentSection>

  <!-- Custom Locales -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Custom Locales</h2>
    <p class="mb-4 text-kumo-strong">
      Register additional translations using <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">registerTranslation</code>:
    </p>
    <CodeBlock
      code={`import { registerTranslation } from "@cloudflare/kumo";
import type { KumoTranslation } from "@cloudflare/kumo";

const th: KumoTranslation = {
  $code: "th",
  $name: "ไทย",
  $dir: "ltr",
  close: "ปิด",
  copy: "คัดลอก",
  // ... all other keys
};

registerTranslation(th);`}
      lang="ts"
    />
    <div class="mt-4">
      <Callout type="warning">
        Custom translations should still provide <strong>all</strong> keys in the <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">KumoTranslation</code> interface. TypeScript enforces completeness, and runtime lookup preserves per-key English fallback semantics.
      </Callout>
    </div>
  </ComponentSection>

  <!-- API Reference -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">API Reference</h2>
    <div class="space-y-6">
      <div>
        <h3 class="mb-2 text-lg font-semibold"><code class="text-base">useLocalize()</code></h3>
        <p class="mb-2 text-kumo-strong">React hook providing localized term lookup and Intl formatting.</p>
        <CodeBlock
          code={`const { term, date, number, lang, dir } = useLocalize();

term("close")                    // "Close"
term("showing-range", 1, 10, 50) // "Showing 1-10 of 50"
date(new Date(), { month: "long" }) // "March"
number(1234.5)                   // "1,234.5"
lang()                           // "en"
dir()                            // "ltr"`}
          lang="ts"
        />
      </div>
      <div>
        <h3 class="mb-2 text-lg font-semibold"><code class="text-base">KumoLocaleProvider</code></h3>
        <p class="mb-2 text-kumo-strong">Override locale or detection for a subtree. Nestable — innermost wins, with config inheritance.</p>
        <CodeBlock
          code={`<KumoLocaleProvider
  locale="ja"
  localeAliases={{ "ja-JP": "ja" }}
  detectLocale={false}
  warnOnUnknownLocale
>
  {/* All useLocalize() calls resolve with provider config */}
</KumoLocaleProvider>`}
          lang="tsx"
        />
      </div>
      <div>
        <h3 class="mb-2 text-lg font-semibold"><code class="text-base">DirectionProvider</code></h3>
        <p class="mb-2 text-kumo-strong">Provide explicit text direction for a subtree. Implemented by Kumo and aligned with Base UI direction semantics. Nestable — innermost wins.</p>
        <CodeBlock
          code={`<DirectionProvider direction="rtl">
  {/* useDirection() returns "rtl" */}
</DirectionProvider>`}
          lang="tsx"
        />
      </div>
      <div>
        <h3 class="mb-2 text-lg font-semibold"><code class="text-base">registerTranslation()</code></h3>
        <p class="mb-2 text-kumo-strong">Register one or more translation objects. English remains the default fallback unless you override provider fallback settings.</p>
        <CodeBlock
          code={`import { registerTranslation } from "@cloudflare/kumo";
registerTranslation(myLocale);`}
          lang="ts"
        />
      </div>
    </div>
  </ComponentSection>

  <!-- Labels Props Interaction -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">Labels Props Interaction</h2>
    <p class="mb-4 text-kumo-strong">
      Some components accept a <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">labels</code> prop for one-off string overrides.
      When provided, the prop value takes precedence over the localized default:
    </p>
    <CodeBlock
      code={`// Uses localized default from active locale
<ClipboardText text="npm install @cloudflare/kumo" />

// Override specific labels
<ClipboardText
  text="npm install @cloudflare/kumo"
  labels={{ copyAction: "Copy command" }}
  tooltip={{ copiedText: "Done!" }}
/>`}
      lang="tsx"
    />
    <div class="mt-4">
      <Callout type="info">
        The <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">labels</code> prop is optional. If omitted, the component falls back to the localized translation. If provided, prop values win for the specified keys.
      </Callout>
    </div>
  </ComponentSection>

  <!-- SSR Considerations -->
  <ComponentSection>
    <h2 class="mb-4 text-2xl font-bold">SSR Considerations</h2>
    <p class="mb-4 text-kumo-strong">
      During server-side rendering, <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">useLocalize()</code> defaults to <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">"en"</code> because <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">document</code> and <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">navigator</code> are not available.
    </p>
    <p class="mb-4 text-kumo-strong">
      To match the server-rendered locale with the client, use <code class="rounded bg-kumo-control px-1 py-0.5 text-sm">KumoLocaleProvider</code>:
    </p>
    <CodeBlock
      code={`// In your SSR entry point, pass the locale from the request
<KumoLocaleProvider locale={requestLocale}>
  <App />
</KumoLocaleProvider>`}
      lang="tsx"
    />
  </ComponentSection>
</DocLayout>
