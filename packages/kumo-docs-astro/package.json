{
  "name": "@cloudflare/kumo-docs-astro",
  "version": "1.3.6",
  "private": true,
  "type": "module",
  "exports": {
    "./demo-metadata.json": "./dist/demo-metadata.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run codegen:demos && pnpm run codegen:skills && astro build",
    "codegen:demos": "tsx scripts/extract-demo-examples.ts",
    "codegen:skills": "tsx scripts/extract-skills.ts",
    "playground:eval:create-worker": "tsx scripts/eval-playground-scenario.ts",
    "playground:verify": "tsx scripts/verify-playground-panel-a.ts",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "oxlint src/ && node ../../lint/lint-astro-colors.js src/",
    "lint:oxlint": "oxlint src/",
    "lint:astro": "node ../../lint/lint-astro-colors.js src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/sitemap": "^3.7.0",
    "@cloudflare/kumo": "workspace:*",
    "@phosphor-icons/react": "catalog:",
    "astro": "^5.16.7",
    "clsx": "catalog:",
    "echarts": "^6.0.0",
    "match-sorter": "^8.2.0",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "^4.7.2",
    "remark-gfm": "4.0.1",
    "shiki": "^3.23.0",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.1",
    "@emotion/is-prop-valid": "^1.4.0",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/react": "16.3.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "happy-dom": "catalog:",
    "isbot": "catalog:",
    "oxlint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
